<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>CFBundlePackageType</key>
        <string>APPL</string>
        <key>CFBundleName</key>
        <string>DKST Markdown Browser</string>
        <key>CFBundleExecutable</key>
        <string>DKST Markdown Browser</string>
        <key>CFBundleIdentifier</key>
        <string>com.dinkisstyle.mdbrowser</string>
        <key>CFBundleVersion</key>
        <string>1.0.0</string>
        <key>CFBundleGetInfoString</key>
        <string>Built using Wails (https://wails.io)</string>
        <key>CFBundleShortVersionString</key>
        <string>1.0.0</string>
        <key>CFBundleIconFile</key>
        <string>iconfile</string>
        <key>LSMinimumSystemVersion</key>
        <string>10.13.0</string>
        <key>NSHighResolutionCapable</key>
        <string>true</string>
        <key>NSHumanReadableCopyright</key>
        <string>Copyright (C) 2026 DINKI'ssTyle. All rights reserved.</string>

        <!-- 마크다운 파일(.md) 연결 선언 -->
        <key>CFBundleDocumentTypes</key>
        <array>
            <dict>
                <key>CFBundleTypeExtensions</key>
                <array>
                    <string>md</string>
                    <string>markdown</string>
                </array>
                <key>CFBundleTypeName</key>
                <string>Markdown Document</string>
                <key>CFBundleTypeRole</key>
                <string>Viewer</string>
                <key>CFBundleTypeIconFile</key>
                <string>iconfile</string>
                <key>LSItemContentTypes</key>
                <array>
                    <string>net.daringfireball.markdown</string>
                    <string>public.plain-text</string>
                </array>
            </dict>
        </array>

        <!-- 사용자 선택 파일/폴더 접근 권한 (macOS 10.15+) -->
        <!-- OpenFileDialog / OpenDirectoryDialog 사용 시 반드시 필요 -->
        <key>NSOpenPanel</key>
        <dict>
            <key>NSAllowsSpecifyingFileURL</key>
            <true/>
        </dict>

        <!-- 파일 시스템 접근 권한 설명 -->
        <!-- macOS 샌드박스 환경에서 파일 열기용 -->
        <key>com.apple.security.files.user-selected.read-only</key>
        <true/>

        <!-- 로컬 네트워크 (wails localhost 서버) 허용 -->
        <key>NSAppTransportSecurity</key>
        <dict>
            <key>NSAllowsLocalNetworking</key>
            <true/>
        </dict>

        

        
    </dict>
</plist>
